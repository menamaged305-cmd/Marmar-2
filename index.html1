<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Marmar Shopping</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        body {
            font-family: 'Inter', 'Cairo', sans-serif;
            scroll-behavior: smooth;
        }
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
        @keyframes scaleIn {
            from { transform: scale(0.9) translateY(10px); opacity: 0; }
            to { transform: scale(1) translateY(0); opacity: 1; }
        }
        .animate-scale-in {
            animation: scaleIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 flex flex-col min-h-screen relative">

    <header class="sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-slate-100 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            <a href="#" class="flex items-center space-x-2 group" onclick="setCategory('all')">
                <span class="text-2xl font-black bg-gradient-to-r from-violet-600 to-rose-500 bg-clip-text text-transparent tracking-wider">
                    Marmar Shopping
                </span>
            </a>
            <nav class="hidden md:flex space-x-1 lg:space-x-4" id="nav-categories"></nav>
            <div class="flex items-center space-x-4 relative">
                <button onclick="toggleCart()" class="relative p-2.5 text-slate-600 hover:text-violet-600 transition-colors focus:outline-none rounded-full hover:bg-slate-50">
                    <i class="fa-solid fa-bag-shopping text-xl"></i>
                    <span id="cart-badge" class="absolute -top-1 -right-1 bg-rose-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center hidden">0</span>
                </button>
                <div class="relative">
                    <button id="dotsMenuBtn" onclick="toggleDotsMenu()" class="p-2.5 text-slate-600 hover:text-violet-600 transition-colors focus:outline-none rounded-full hover:bg-slate-50" aria-label="More Options">
                        <i class="fa-solid fa-ellipsis-vertical text-xl"></i>
                    </button>
                    <div id="dotsDropdown" class="hidden absolute right-0 mt-3 w-56 bg-white border border-slate-100 rounded-2xl shadow-xl py-2 z-50 transform origin-top-right transition-all">
                        <button onclick="changeLanguage()" class="w-full flex items-center px-4 py-3 text-slate-700 hover:bg-slate-50 transition-colors text-sm">
                            <i class="fa-solid fa-globe mr-3 text-violet-500 w-5"></i>
                            <span id="lang-switch-text">العربية</span>
                        </button>
                        <div id="admin-menu-items" class="contents"></div>
                        <div class="border-t border-slate-100 my-1"></div>
                        <button id="admin-menu-btn" onclick="openAdminModal()" class="w-full flex items-center px-4 py-3 text-slate-700 hover:bg-slate-50 transition-colors text-sm">
                            <i class="fa-solid fa-user-shield mr-3 text-violet-500 w-5"></i>
                            <span id="admin-login-text">Admin Login</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="relative bg-gradient-to-r from-slate-900 via-violet-950 to-slate-900 py-20 px-4 sm:px-6 lg:px-8 text-white overflow-hidden">
        <div class="absolute -top-40 -left-40 w-96 h-96 bg-violet-500/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-rose-500/10 rounded-full blur-3xl"></div>
        <div class="max-w-7xl mx-auto relative z-10 flex flex-col md:flex-row items-center justify-between gap-10">
            <div class="max-w-2xl text-center md:text-left" id="hero-text-container"></div>
            <div class="relative w-full md:w-1/2 flex justify-center">
                <div class="relative max-w-sm rounded-3xl overflow-hidden shadow-2xl border-4 border-white/10 group">
                    <img id="hero-image" src="https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=600&q=80" alt="Marmar Shopping Sale" class="w-full object-cover h-80 transition-transform duration-700 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex items-end p-6">
                        <span class="bg-rose-500 text-white text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider">Marmar Selection</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="md:hidden sticky top-20 z-30 bg-white border-b border-slate-100 flex justify-around py-3 px-2 shadow-sm" id="mobile-categories-bar"></div>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 flex-grow">
        <div class="mb-10 bg-gradient-to-r from-violet-50 to-indigo-50 border border-violet-100 rounded-3xl p-6 shadow-sm">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                <div class="max-w-xl">
                    <h3 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                        <span class="p-2 bg-violet-200/60 text-violet-700 rounded-xl animate-pulse"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
                        <span id="ai-search-title">✨ AI Smart Fashion Search</span>
                    </h3>
                    <p class="text-xs text-slate-500 mt-1" id="ai-search-desc">Ask Marmar AI for anything (e.g. "Warm coat for kids", "فستان حرير ناعم ومميز") and let the AI instantly curate the best outfits for you!</p>
                </div>
                <form onsubmit="handleAISmartSearch(event)" class="w-full md:w-auto flex flex-grow max-w-xl gap-2">
                    <input type="text" id="ai-search-input" required class="flex-grow px-4 py-3 rounded-xl border border-violet-200/70 focus:ring-2 focus:ring-violet-500 focus:outline-none text-sm transition-all bg-white" placeholder="Type your fashion vibes here...">
                    <button type="submit" id="ai-search-btn" class="bg-violet-600 hover:bg-violet-700 text-white font-bold px-5 py-3 rounded-xl transition-all shadow-md flex items-center gap-2 whitespace-nowrap text-sm">
                        <i class="fa-solid fa-magnifying-glass"></i> <span id="ai-search-btn-text">✨ Search</span>
                    </button>
                </form>
            </div>
            <div id="ai-filter-active-bar" class="hidden mt-4 pt-3 border-t border-violet-100 flex items-center justify-between">
                <span class="text-xs text-violet-700 font-semibold" id="ai-search-status-txt">AI filtered matching products</span>
                <button onclick="clearAISearchFilter()" class="text-xs font-bold text-rose-500 hover:text-rose-700 flex items-center gap-1">
                    <i class="fa-solid fa-circle-xmark"></i> <span id="clear-ai-search-lbl">Clear Search</span>
                </button>
            </div>
        </div>

        <div id="admin-dashboard-container" class="hidden mb-12 bg-white rounded-3xl border border-violet-100 p-6 sm:p-8 shadow-md">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-100 pb-6 mb-6 gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                        <span class="p-2 bg-violet-100 text-violet-600 rounded-xl"><i class="fa-solid fa-lock-open"></i></span>
                        <span id="admin-panel-title">Marmar Shopping Dashboard</span>
                    </h2>
                    <p class="text-sm text-slate-500 mt-1" id="admin-panel-subtitle">Manage store products and view incoming customer orders</p>
                </div>
                <div class="flex flex-wrap gap-2 w-full sm:w-auto">
                    <button onclick="toggleAddProductForm()" class="bg-violet-600 hover:bg-violet-700 text-white font-semibold px-4 py-2.5 rounded-xl transition-all shadow-lg shadow-violet-600/20 text-sm flex items-center gap-2">
                        <i class="fa-solid fa-plus"></i> <span id="add-prod-btn-text">Add Product</span>
                    </button>
                    <button onclick="openInventoryModal()" class="bg-indigo-50 text-indigo-600 hover:bg-indigo-100 font-semibold px-4 py-2.5 rounded-xl transition-all text-sm flex items-center gap-2">
                        <i class="fa-solid fa-boxes-stacked"></i> <span id="panel-inventory-btn">Inventory Audit</span>
                    </button>
                    <button onclick="logoutAdmin()" class="bg-rose-50 text-rose-600 hover:bg-rose-100 font-semibold px-4 py-2.5 rounded-xl transition-all text-sm flex items-center gap-2 ml-auto sm:ml-0">
                        <i class="fa-solid fa-right-from-bracket"></i> <span id="logout-btn-text">Logout</span>
                    </button>
                </div>
            </div>

            <div id="add-product-drawer" class="hidden mb-8 bg-slate-50 p-6 rounded-2xl border border-slate-200 animate-scale-in">
                <h3 class="text-lg font-bold text-slate-800 mb-4" id="form-heading">Create New Product Listing</h3>
                <form id="product-form" onsubmit="handleProductSubmit(event)">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-600 uppercase mb-2" id="lbl-title">Product Title</label>
                            <input type="text" id="form-title" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all" placeholder="Enter name">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-600 uppercase mb-2" id="lbl-price">Price (EGP)</label>
                            <input type="number" step="0.01" id="form-price" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all" placeholder="e.g. 1500">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-600 uppercase mb-2" id="lbl-category">Category</label>
                            <select id="form-category" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all">
                                <option value="men">Men</option>
                                <option value="women">Women</option>
                                <option value="children">Children</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-600 uppercase mb-2" id="lbl-img">Image URL</label>
                            <input type="url" id="form-img" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all" placeholder="https://unsplash.com/...">
                        </div>
                        <div class="md:col-span-2">
                            <div class="flex justify-between items-center mb-2">
                                <label class="block text-xs font-bold text-slate-600 uppercase" id="lbl-desc">Description</label>
                                <button type="button" onclick="generateAIDescription()" class="bg-violet-50 border border-violet-200 text-violet-700 hover:bg-violet-100 font-semibold px-3 py-1.5 rounded-xl transition-all text-xs flex items-center gap-1.5">
                                    <i class="fa-solid fa-wand-magic-sparkles text-violet-600 animate-pulse"></i>
                                    <span id="ai-generate-desc-btn">✨ Write with Gemini AI</span>
                                </button>
                            </div>
                            <textarea id="form-desc" rows="3" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all" placeholder="Write description or use the AI generator..."></textarea>
                        </div>
                    </div>
                    <div class="mt-4 flex justify-end gap-2">
                        <button type="button" onclick="toggleAddProductForm()" class="bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold px-4 py-2 rounded-xl text-sm" id="btn-cancel">Cancel</button>
                        <button type="submit" class="bg-violet-600 hover:bg-violet-700 text-white font-semibold px-6 py-2 rounded-xl text-sm" id="btn-save-prod">Save Product</button>
                    </div>
                </form>
            </div>

            <div>
                <h3 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-file-invoice text-rose-500"></i>
                    <span id="orders-sec-title">Incoming Orders</span>
                    <span id="orders-badge" class="bg-rose-500 text-white text-xs px-2.5 py-1 rounded-full">0</span>
                </h3>
                <div class="overflow-x-auto rounded-2xl border border-slate-100 bg-slate-50/55 max-h-96">
                    <table class="w-full text-left border-collapse" id="orders-table"></table>
                </div>
            </div>
        </div>

        <div class="flex justify-between items-center mb-8">
            <div>
                <span class="text-violet-600 font-bold uppercase tracking-wider text-xs block mb-1">Marmar Shopping Collection</span>
                <h2 class="text-2xl font-bold text-slate-800" id="current-category-label">All Products</h2>
            </div>
            <span class="text-sm text-slate-400 font-medium" id="product-count">0 items found</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" id="product-grid"></div>
    </main>

    <div id="cart-drawer" class="fixed inset-0 z-50 overflow-hidden hidden" aria-labelledby="slide-over-title" role="dialog" aria-modal="true">
        <div class="absolute inset-0 overflow-hidden">
            <div onclick="toggleCart()" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity"></div>
            <div class="pointer-events-none fixed inset-y-0 right-0 flex max-w-full pl-10">
                <div class="pointer-events-auto w-screen max-w-md">
                    <div class="flex h-full flex-col bg-white shadow-2xl rounded-l-3xl overflow-hidden">
                        <div class="flex items-center justify-between px-6 py-6 border-b border-slate-100">
                            <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                <i class="fa-solid fa-bag-shopping text-violet-600"></i>
                                <span id="cart-title">Your Cart</span>
                            </h2>
                            <button onclick="toggleCart()" class="text-slate-400 hover:text-slate-600 p-1.5 hover:bg-slate-100 rounded-full transition-all">
                                <i class="fa-solid fa-xmark text-lg"></i>
                            </button>
                        </div>
                        <div class="flex-1 overflow-y-auto px-6 py-6 space-y-4" id="cart-items-list"></div>
                        <div class="border-t border-slate-100 px-6 py-6 bg-slate-50/80">
                            <div class="flex justify-between text-base font-semibold text-slate-950 mb-4">
                                <span id="cart-lbl-total">Total Price:</span>
                                <span id="cart-total-value">0 ج.م</span>
                            </div>
                            <div class="space-y-2">
                                <button onclick="openCheckoutModal()" class="w-full py-3 px-4 bg-gradient-to-r from-violet-600 to-rose-500 hover:from-violet-700 hover:to-rose-600 text-white text-center font-bold rounded-xl shadow-lg shadow-violet-600/15 transition-all" id="btn-checkout-label">Proceed to Checkout</button>
                                <button onclick="toggleCart()" class="w-full text-center text-sm font-semibold text-slate-500 hover:text-slate-700 py-2" id="btn-continue-label">Continue Shopping</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="admin-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
        <div class="bg-white rounded-3xl max-w-md w-full p-6 sm:p-8 shadow-2xl relative border border-slate-100">
            <button onclick="closeAdminModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 p-1.5 hover:bg-slate-50 rounded-full"><i class="fa-solid fa-xmark text-lg"></i></button>
            <div class="text-center mb-6">
                <span class="p-3 bg-violet-100 text-violet-600 rounded-2xl inline-block mb-3"><i class="fa-solid fa-shield-halved text-2xl"></i></span>
                <h3 class="text-xl font-bold text-slate-900" id="admin-login-head">Admin Authentication</h3>
                <p class="text-sm text-slate-400 mt-1" id="admin-login-sub">Access shop editing, price adjustments & view orders</p>
            </div>
            <form onsubmit="handleAdminLogin(event)" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-600 uppercase mb-2" id="lbl-password">Admin Password</label>
                    <input type="password" id="admin-password-input" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all" placeholder="Enter password">
                </div>
                <div id="login-error" class="hidden text-rose-600 bg-rose-50 border border-rose-100 p-3 rounded-xl text-sm text-center font-medium">Incorrect password!</div>
                <button type="submit" class="w-full py-3 bg-violet-600 hover:bg-violet-700 text-white font-bold rounded-xl shadow-lg transition-all" id="btn-login-submit">Login</button>
            </form>
        </div>
    </div>

    <div id="checkout-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
        <div class="bg-white rounded-3xl max-w-lg w-full p-6 sm:p-8 shadow-2xl relative max-h-[90vh] overflow-y-auto border border-slate-100">
            <button onclick="closeCheckoutModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 p-1.5 hover:bg-slate-50 rounded-full"><i class="fa-solid fa-xmark text-lg"></i></button>
            <div class="mb-6">
                <h3 class="text-xl font-bold text-slate-900" id="checkout-head">Complete Order Placement</h3>
                <p class="text-sm text-slate-400 mt-1" id="checkout-sub">We offer Cash on Delivery. Please fill in details below:</p>
            </div>
            <form onsubmit="handleCheckoutSubmit(event)" class="space-y-4">
                <div><label class="block text-xs font-bold text-slate-600 uppercase mb-2" id="lbl-cust-name">Full Name</label><input type="text" id="cust-name" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all" placeholder="e.g. Aly Ahmed"></div>
                <div><label class="block text-xs font-bold text-slate-600 uppercase mb-2" id="lbl-cust-phone">Phone Number</label><input type="tel" id="cust-phone" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all" placeholder="e.g. +201000000000"></div>
                <div><label class="block text-xs font-bold text-slate-600 uppercase mb-2" id="lbl-cust-addr">Delivery Address</label><input type="text" id="cust-addr" required class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500 focus:outline-none transition-all" placeholder="Street, Building, City"></div>
                <div class="bg-slate-50 p-4 rounded-xl space-y-2 text-sm border border-slate-100">
                    <div class="flex justify-between font-bold text-slate-900 border-t border-slate-200 pt-2 mt-1">
                        <span id="lbl-summary-total">Total:</span>
                        <span id="summary-total-value" class="font-extrabold">0 ج.م</span>
                    </div>
                </div>
                <button type="submit" class="w-full py-3 bg-rose-500 hover:bg-rose-600 text-white font-bold rounded-xl shadow-lg transition-all" id="btn-submit-order">Confirm Order</button>
            </form>
        </div>
    </div>

    <div id="inventory-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
        <div class="bg-white rounded-3xl max-w-4xl w-full p-6 sm:p-8 shadow-2xl relative max-h-[90vh] flex flex-col border border-slate-100">
            <button onclick="closeInventoryModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 p-1.5 hover:bg-slate-50 rounded-full"><i class="fa-solid fa-xmark text-lg"></i></button>
            <div class="mb-6 flex items-center gap-3">
                <span class="p-3 bg-indigo-100 text-indigo-600 rounded-2xl"><i class="fa-solid fa-boxes-stacked text-2xl"></i></span>
                <div>
                    <h3 class="text-xl font-bold text-slate-900" id="inventory-modal-title">Marmar Shopping Inventory Audit</h3>
                    <p class="text-sm text-slate-400 mt-1" id="inventory-modal-sub">Comprehensive overview of active products and total valuation</p>
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100"><span class="text-xs text-slate-400 font-bold uppercase block mb-1" id="inv-total-items-lbl">Total Catalog Items</span><span id="inv-total-count" class="text-2xl font-black text-slate-900">0</span></div>
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100"><span class="text-xs text-slate-400 font-bold uppercase block mb-1" id="inv-total-qty-lbl">Total Stock Quantity</span><span id="inv-total-quantity" class="text-2xl font-black text-indigo-600">0 units</span></div>
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100"><span class="text-xs text-slate-400 font-bold uppercase block mb-1" id="inv-total-value-lbl">Total Inventory Valuation</span><span id="inv-total-value" class="text-2xl font-black text-rose-500">0 ج.م</span></div>
            </div>
            <div class="flex-grow overflow-y-auto border border-slate-100 rounded-2xl bg-slate-50/50">
                <table class="w-full text-left border-collapse text-xs" id="inventory-table"></table>
            </div>
            <div class="mt-6 flex justify-end">
                <button onclick="closeInventoryModal()" class="px-6 py-2.5 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-xl transition-all" id="btn-close-inv">Close Audit Sheet</button>
            </div>
        </div>
    </div>

    <div id="confirm-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
        <div class="bg-white rounded-3xl max-w-sm w-full p-6 shadow-2xl text-center border border-slate-100 animate-scale-in">
            <span class="p-4 bg-rose-100 text-rose-500 rounded-2xl inline-block mb-4"><i class="fa-solid fa-circle-exclamation text-3xl"></i></span>
            <h3 class="text-lg font-bold text-slate-950" id="confirm-modal-message">Are you sure?</h3>
            <div class="mt-6 flex gap-3">
                <button id="confirm-modal-cancel" class="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl text-sm transition-all">Cancel</button>
                <button id="confirm-modal-ok" class="flex-1 py-2.5 bg-rose-500 hover:bg-rose-600 text-white font-bold rounded-xl text-sm transition-all shadow-md">Confirm</button>
            </div>
        </div>
    </div>

    <div id="ai-chat-window" class="fixed bottom-24 right-6 w-[360px] sm:w-[400px] h-[520px] bg-white rounded-3xl shadow-2xl border border-slate-100 flex flex-col overflow-hidden transition-all duration-300 z-50 transform scale-95 opacity-0 pointer-events-none">
        <div class="bg-gradient-to-r from-violet-600 to-indigo-600 text-white p-4 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="relative w-10 h-10 bg-white/20 rounded-full flex items-center justify-center border border-white/20 shadow-inner">
                    <i class="fa-solid fa-wand-magic-sparkles text-rose-300 text-lg animate-pulse"></i>
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-emerald-500 rounded-full border-2 border-white"></span>
                </div>
                <div>
                    <h4 class="font-extrabold text-sm tracking-wide">Marmar AI</h4>
                    <p class="text-[10px] text-violet-200 font-medium" id="ai-status">Stylist is Online</p>
                </div>
            </div>
            <button onclick="toggleAIChat()" class="text-white/80 hover:text-white p-1.5 hover:bg-white/10 rounded-full transition-all"><i class="fa-solid fa-xmark text-lg"></i></button>
        </div>
        <div id="ai-chat-body" class="flex-1 overflow-y-auto p-4 space-y-4 bg-slate-50/75"></div>
        <form onsubmit="handleAISend(event)" class="p-3 bg-white border-t border-slate-100 flex items-center gap-2">
            <input type="text" id="ai-input" required class="flex-grow px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500 focus:outline-none text-sm transition-all" placeholder="Ask Marmar Stylist anything...">
            <button type="submit" class="p-2.5 bg-violet-600 hover:bg-violet-700 text-white rounded-xl transition-all shadow-md shadow-violet-600/10 flex items-center justify-center"><i class="fa-solid fa-paper-plane"></i></button>
        </form>
    </div>

    <button onclick="toggleAIChat()" class="fixed bottom-6 right-6 z-50 p-4 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-700 hover:to-indigo-700 text-white rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-all flex items-center justify-center gap-2 group" aria-label="AI Personal Stylist">
        <i class="fa-solid fa-wand-magic-sparkles text-xl group-hover:rotate-12 transition-transform"></i>
        <span class="max-w-0 overflow-hidden group-hover:max-w-xs transition-all duration-500 ease-in-out font-bold text-sm whitespace-nowrap" id="ai-floating-label">AI Stylist</span>
    </button>

    <div id="toast-notif" class="fixed bottom-6 left-6 z-50 bg-slate-900 text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center space-x-3 max-w-md transform translate-y-20 opacity-0 transition-all duration-300">
        <span class="p-1.5 bg-violet-500 text-white rounded-lg flex items-center justify-center"><i class="fa-solid fa-circle-check"></i></span>
        <p id="toast-text" class="text-sm font-semibold"></p>
    </div>

    <footer class="bg-slate-900 text-slate-400 py-12 border-t border-slate-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="text-center md:text-left">
                <span class="text-xl font-extrabold text-white tracking-wider">Marmar Shopping</span>
                <p class="text-xs text-slate-500 mt-2" id="footer-rights">© 2026 Marmar Shopping. All rights reserved.</p>
            </div>
            <div class="flex gap-4 text-sm font-medium">
                <a href="#" class="hover:text-white transition-colors" onclick="setCategory('men')">Men</a>
                <a href="#" class="hover:text-white transition-colors" onclick="setCategory('women')">Women</a>
                <a href="#" class="hover:text-white transition-colors" onclick="setCategory('children')">Children</a>
            </div>
        </div>
    </footer>

